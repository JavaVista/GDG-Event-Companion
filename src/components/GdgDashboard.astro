---
// GDG Event Companion Showcase Dashboard
// Implements Material Design 3 guidelines, dynamic themes, and swappable global icons.
---

<div class="min-h-screen flex flex-col transition-colors duration-300">
  <!-- HEADER -->
  <header
    class="sticky top-0 z-50 bg-surface/85 backdrop-blur-md border-b border-outline/50 px-6 py-4 flex items-center justify-between"
  >
    <div class="flex items-center gap-3">
      <!-- GDG Color Blocks to symbolize the branding -->
      <div class="flex gap-1">
        <span
          class="w-3 h-3 rounded-full bg-primary"
          title="Primary (Blue/Holiday)"></span>
        <span
          class="w-3 h-3 rounded-full bg-secondary"
          title="Secondary (Green)"></span>
        <span
          class="w-3 h-3 rounded-full bg-tertiary"
          title="Tertiary (Yellow/Gold)"></span>
        <span class="w-3 h-3 rounded-full bg-error" title="Error/Pastel Red"
        ></span>
      </div>
      <h1 class="text-xl font-bold tracking-tight text-on-background">
        GDG <span class="text-primary">Event Companion</span>
      </h1>
    </div>

    <!-- Theme Switcher Dropdown (central control panel) -->
    <div class="flex items-center gap-3">
      <label
        for="theme-select"
        class="text-sm font-medium text-on-surface-variant hidden sm:inline-block"
        >Active Theme:</label
      >
      <select
        id="theme-select"
        class="select-theme bg-surface-variant text-on-surface-variant text-sm font-medium py-2 px-4 pr-8 rounded-full border border-outline hover:border-primary transition-all duration-200 cursor-pointer focus:outline-none appearance-none"
      >
        <option value="system">Google Developer Groups (System Default)</option>
        <option value="gdg-light">Google Developer Groups (Light Mode)</option>
        <option value="gdg-dark">Google Developer Groups (Dark Mode)</option>
        <option value="holiday">🎄 Holiday Celebration (Custom Theme)</option>
      </select>
    </div>
  </header>
</div>

<!-- MAIN CONTAINER -->
<main class="flex-grow max-w-6xl w-full mx-auto px-6 py-8 flex flex-col gap-8">
  <!-- HERO SECTION (Elevated Card) -->
  <section
    class="card card-elevated flex flex-col md:flex-row gap-8 items-center bg-gradient-to-br from-surface to-primary-container/10"
  >
    <div class="flex-grow flex flex-col gap-4 text-left">
      <div
        class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-primary-container text-on-primary-container text-xs font-semibold self-start uppercase tracking-wider"
      >
        <span class="icon-event w-4 h-4"></span>
        Annual DevFest 2026
      </div>
      <h2 class="text-3xl sm:text-4xl font-extrabold leading-tight">
        Where Technology <br />Meets <span
          class="text-primary underline decoration-wavy decoration-secondary decoration-2"
          >Community</span
        >
      </h2>
      <p class="text-on-surface-variant text-base sm:text-lg max-w-xl">
        Join us for the largest developer festival in the region. Celebrating
        local innovation, expert learning, and collaborative networking.
        Customize your experience live!
      </p>
      <div class="flex flex-wrap gap-3 mt-2">
        <button class="btn btn-filled"> RSVP Now </button>
        <button class="btn btn-outlined"> View Schedule </button>
      </div>
    </div>
    <!-- Decorative Graphic Panel using MD3 Cards -->
    <div class="w-full md:w-80 flex flex-col gap-3 shrink-0">
      <div class="card card-filled flex items-center gap-4 py-4">
        <div
          class="w-12 h-12 rounded-full bg-primary text-on-primary flex items-center justify-center shrink-0"
        >
          <span class="icon-event"></span>
        </div>
        <div>
          <div class="text-xs text-on-surface-variant font-medium">WHEN</div>
          <div class="text-sm font-bold">November 14 - 15, 2026</div>
        </div>
      </div>
      <div class="card card-filled flex items-center gap-4 py-4">
        <div
          class="w-12 h-12 rounded-full bg-secondary text-on-secondary flex items-center justify-center shrink-0"
        >
          <span class="icon-location"></span>
        </div>
        <div>
          <div class="text-xs text-on-surface-variant font-medium">WHERE</div>
          <div class="text-sm font-bold">Tech Innovation Hub / Hybrid</div>
        </div>
      </div>
    </div>
  </section>

  <!-- THEME SWAP EXPLANATION ALERT -->
  <div
    class="card card-filled border border-primary/20 flex gap-4 bg-primary-container/10"
  >
    <div class="text-primary text-2xl shrink-0 mt-0.5">ℹ️</div>
    <div class="flex flex-col gap-1">
      <h3 class="text-sm font-bold text-on-primary-container">
        How to test theme & icon swappability:
      </h3>
      <p class="text-xs text-on-surface-variant leading-relaxed">
        Open the <strong>Active Theme</strong> dropdown in the header and choose <strong
          >Holiday Celebration</strong
        >. Notice how the color system completely switches to Christmas-inspired
        tones (Pine Green, Berry Red, and Gold), and the icons dynamically
        update instantly! The Calendar icon changes to a <strong
          >Christmas Tree</strong
        >, the Location pin becomes a <strong>Snowflake</strong>, the Speaker
        icon becomes a <strong>Santa Hat helper</strong>, and the Attendee Smile
        Badge becomes a <strong>Gift Box</strong>. This is accomplished cleanly
        by mapping CSS mask variables in <a
          href="file:///Users/javi/Desktop/CodeVista/GDG/GDG%20Event%20Companion/src/styles/global.css"
          class="text-primary hover:underline font-semibold">global.css</a
        >.
      </p>
    </div>
  </div>

  <!-- INTERACTIVE SECTION GRID -->
  <section class="grid grid-cols-1 md:grid-cols-3 gap-6">
    <!-- CARD 1: SPEAKERS (Elevated Card) -->
    <div class="card card-elevated flex flex-col justify-between gap-6">
      <div class="flex flex-col gap-4">
        <div class="flex items-center justify-between">
          <div
            class="w-10 h-10 rounded-xl bg-secondary/15 text-secondary flex items-center justify-center"
          >
            <span class="icon-speaker"></span>
          </div>
          <span
            class="text-xs font-semibold text-secondary px-2.5 py-1 rounded-full bg-secondary/10"
            >Keynotes</span
          >
        </div>
        <div>
          <h3 class="text-lg font-bold">Featured Speakers</h3>
          <p class="text-sm text-on-surface-variant mt-1 leading-relaxed">
            Learn from industry leaders, Google Developer Experts, and open
            source developers building the future of AI and Web.
          </p>
        </div>
        <!-- Simple Speaker Item list -->
        <ul class="flex flex-col gap-3 mt-2 border-t border-outline/30 pt-3">
          <li class="flex items-center gap-3 text-sm">
            <div
              class="w-8 h-8 rounded-full bg-surface-variant flex items-center justify-center font-bold text-xs text-on-surface-variant"
            >
              JD
            </div>
            <div>
              <div class="font-semibold text-on-surface">Dr. Jane Doe</div>
              <div class="text-xs text-on-surface-variant">
                Director of AI @ Google
              </div>
            </div>
          </li>
          <li class="flex items-center gap-3 text-sm">
            <div
              class="w-8 h-8 rounded-full bg-surface-variant flex items-center justify-center font-bold text-xs text-on-surface-variant"
            >
              AS
            </div>
            <div>
              <div class="font-semibold text-on-surface">Alex Smith</div>
              <div class="text-xs text-on-surface-variant">
                GDE in Web Technologies
              </div>
            </div>
          </li>
        </ul>
      </div>
      <button class="btn btn-tonal w-full mt-2"> Meet all speakers </button>
    </div>

    <!-- CARD 2: SESSIONS (Filled Card) -->
    <div class="card card-filled flex flex-col justify-between gap-6">
      <div class="flex flex-col gap-4">
        <div class="flex items-center justify-between">
          <div
            class="w-10 h-10 rounded-xl bg-primary/15 text-primary flex items-center justify-center"
          >
            <span class="icon-event"></span>
          </div>
          <span
            class="text-xs font-semibold text-primary px-2.5 py-1 rounded-full bg-primary/10"
            >3 Track Tracks</span
          >
        </div>
        <div>
          <h3 class="text-lg font-bold">Agenda & Tracks</h3>
          <p class="text-sm text-on-surface-variant mt-1 leading-relaxed">
            Explore custom learning tracks designed for beginners and veterans
            alike. Select from over 25+ tech talks and workshops.
          </p>
        </div>
        <!-- Agenda sneak peek -->
        <div
          class="flex flex-col gap-3 mt-2 border-t border-outline-variant pt-3"
        >
          <div class="text-xs flex justify-between font-semibold">
            <span class="text-primary">Track 1: AI & ML</span>
            <span class="text-on-surface-variant">09:00 AM</span>
          </div>
          <div class="text-xs flex justify-between font-semibold">
            <span class="text-secondary">Track 2: Web & Mobile</span>
            <span class="text-on-surface-variant">10:30 AM</span>
          </div>
          <div class="text-xs flex justify-between font-semibold">
            <span class="text-tertiary text-opacity-80"
              >Track 3: Cloud & Devops</span
            >
            <span class="text-on-surface-variant">01:00 PM</span>
          </div>
        </div>
      </div>
      <button class="btn btn-filled w-full mt-2"> Reserve seat </button>
    </div>

    <!-- CARD 3: BADGES (Outlined Card) -->
    <div class="card card-outlined flex flex-col justify-between gap-6">
      <div class="flex flex-col gap-4">
        <div class="flex items-center justify-between">
          <div
            class="w-10 h-10 rounded-xl bg-tertiary/15 text-tertiary flex items-center justify-center"
          >
            <span class="icon-badge"></span>
          </div>
          <span
            class="text-xs font-semibold text-tertiary px-2.5 py-1 rounded-full bg-tertiary/10"
            >Digital Badges</span
          >
        </div>
        <div>
          <h3 class="text-lg font-bold">Attendee Badges</h3>
          <p class="text-sm text-on-surface-variant mt-1 leading-relaxed">
            Collect event badges and showcase your learning. Badges
            automatically customize to your theme layout!
          </p>
        </div>
        <!-- Badge items -->
        <div
          class="flex justify-around gap-2 mt-4 bg-surface-variant/40 p-4 rounded-xl border border-outline/30"
        >
          <div class="flex flex-col items-center gap-1.5">
            <div
              class="w-12 h-12 rounded-full bg-primary/10 text-primary flex items-center justify-center"
            >
              <span class="icon-badge w-6 h-6"></span>
            </div>
            <span class="text-[10px] font-bold text-center">Early Bird</span>
          </div>
          <div class="flex flex-col items-center gap-1.5">
            <div
              class="w-12 h-12 rounded-full bg-secondary/10 text-secondary flex items-center justify-center"
            >
              <span class="icon-badge w-6 h-6"></span>
            </div>
            <span class="text-[10px] font-bold text-center">Builder</span>
          </div>
          <div class="flex flex-col items-center gap-1.5">
            <div
              class="w-12 h-12 rounded-full bg-tertiary/10 text-tertiary flex items-center justify-center"
            >
              <span class="icon-badge w-6 h-6"></span>
            </div>
            <span class="text-[10px] font-bold text-center">Learner</span>
          </div>
        </div>
      </div>
      <button class="btn btn-outlined w-full mt-2"> Claim My Badges </button>
    </div>
  </section>

  <!-- COMPONENT BUTTON DEFAULTS SHOWCASE -->
  <section class="card card-outlined flex flex-col gap-6 mt-4">
    <div>
      <h3 class="text-lg font-bold">Material Design 3 Button Defaults</h3>
      <p class="text-sm text-on-surface-variant mt-1">
        These buttons leverage global defaults defined in <code
          >src/styles/global.css</code
        > and respond automatically to theme states.
      </p>
    </div>
    <div class="flex flex-wrap gap-4 items-center">
      <button class="btn btn-filled"> Filled Button </button>
      <button class="btn btn-tonal"> Tonal Button </button>
      <button class="btn btn-outlined"> Outlined Button </button>
      <button class="btn btn-text"> Text Button </button>
    </div>
  </section>
</main>

<!-- FOOTER -->
<footer
  class="bg-surface border-t border-outline/50 py-8 px-6 mt-16 text-center text-sm text-on-surface-variant"
>
  <div
    class="max-w-6xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4"
  >
    <div class="flex items-center gap-2">
      <div
        class="w-5 h-5 rounded bg-primary/20 text-primary flex items-center justify-center text-xs"
      >
        G
      </div>
      <span>Google Developer Groups - Developer Showcase</span>
    </div>
    <div class="flex gap-6">
      <a href="#" class="hover:text-primary hover:underline transition-all"
        >Code of Conduct</a
      >
      <a href="#" class="hover:text-primary hover:underline transition-all"
        >Privacy Policy</a
      >
    </div>
  </div>
</footer>

<script>
  // Dynamic client-side theme swappability
  const themeSelect = document.getElementById(
    'theme-select'
  ) as HTMLSelectElement;
  if (themeSelect) {
    // Check local storage or existing DOM theme
    const savedTheme = localStorage.getItem('gdg-active-theme');
    if (savedTheme) {
      themeSelect.value = savedTheme;
      if (savedTheme === 'system') {
        document.documentElement.removeAttribute('data-theme');
      } else {
        document.documentElement.setAttribute('data-theme', savedTheme);
      }
    }

    themeSelect.addEventListener('change', (e) => {
      const selected = (e.target as HTMLSelectElement).value;
      localStorage.setItem('gdg-active-theme', selected);

      if (selected === 'system') {
        document.documentElement.removeAttribute('data-theme');
      } else {
        document.documentElement.setAttribute('data-theme', selected);
      }
    });
  }
</script>
