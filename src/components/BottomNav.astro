---
import Icon from './Icon.astro';
import type { SemanticIconName } from '../config/icons';

const pathname = Astro.url.pathname;
const normalizePath = (path: string) => path.replace(/\/$/, '') || '/';
const activePath = normalizePath(pathname);

const navItems = [
  { label: 'Home', icon: 'home' as SemanticIconName, href: '/' },
  { label: 'QR Center', icon: 'qr' as SemanticIconName, href: '/qr' },
  { label: 'Events', icon: 'calendar' as SemanticIconName, href: '/events' },
  { label: 'More', icon: 'more' as SemanticIconName, href: '/more' },
];

const isActive = (href: string) => {
  const normalizedHref = normalizePath(href);
  if (normalizedHref === '/') {
    return activePath === '/';
  }
  return activePath.startsWith(normalizedHref);
};
---

<nav
  class="w-full h-20 flex justify-around items-center bg-surface/90 backdrop-blur-md px-2"
  aria-label="Bottom Navigation"
>
  {
    navItems.map((item) => {
      const active = isActive(item.href);
      return (
        <a
          href={item.href}
          class="flex flex-col items-center justify-center flex-1 h-full group focus:outline-none relative"
          aria-current={active ? 'page' : undefined}
        >
          {/* Active indicator container (Pill) */}
          <div
            class={`relative flex items-center justify-center w-16 h-8 rounded-full transition-all duration-200 ease-out mb-1 ${
              active
                ? 'bg-secondary-container text-on-secondary-container scale-100 shadow-elevation-1'
                : 'text-on-surface-variant hover:bg-on-surface/5 active:scale-95'
            }`}
          >
            <Icon
              name={item.icon}
              size={22}
              class="transition-transform duration-200 group-hover:scale-105"
            />
          </div>
          {/* Text Label */}
          <span
            class={`text-[11px] tracking-wide transition-colors duration-200 ${
              active
                ? 'text-on-surface font-semibold'
                : 'text-on-surface-variant/80 font-medium group-hover:text-on-surface'
            }`}
          >
            {item.label}
          </span>
        </a>
      );
    })
  }
</nav>
