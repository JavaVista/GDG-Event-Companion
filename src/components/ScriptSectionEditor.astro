---
import Icon from './Icon.astro';

interface Props {
  eventId: string;
}

const { eventId } = Astro.props;
---

<div
  id="script-editor-container"
  class="flex flex-col gap-4 pb-20"
  data-event-id={eventId}
>
  <div class="flex justify-between items-center select-none">
    <h3
      class="text-xs font-bold text-on-surface-variant uppercase tracking-wider"
    >
      Script Sections
    </h3>
    <div class="flex items-center gap-2">
      <span
        id="editor-saved-msg"
        class="text-xs font-bold text-success opacity-0 transition-opacity duration-200"
      >
        Saved!
      </span>
      <button
        id="btn-markdown-hint"
        type="button"
        class="text-xs font-semibold text-on-surface-variant hover:text-primary flex items-center gap-1 px-2.5 py-1 rounded-xl bg-surface-variant/40 hover:bg-surface-variant/80 border border-outline/15 transition-all cursor-pointer active:scale-95"
        title="Markdown Formatting Guide"
      >
        <span>💡</span>
      </button>
    </div>
  </div>

  <!-- Inline Undo Banner (In-Flow, Non-Floating) -->
  <div
    id="inline-undo-banner"
    class="hidden bg-surface-variant/50 border border-outline/15 rounded-xl px-3.5 py-2.5 flex items-center justify-between text-xs text-on-surface transition-all"
  >
    <span id="inline-undo-text" class="truncate font-medium"
      >Section deleted</span
    >
    <button
      id="btn-inline-undo"
      type="button"
      class="text-xs font-black text-success hover:underline shrink-0 ml-2 cursor-pointer uppercase tracking-wider"
    >
      Undo
    </button>
  </div>

  <!-- Sections Accordion List -->
  <div id="sections-list" class="flex flex-col gap-2.5">
    <!-- Populated by Client Script -->
  </div>

  <!-- Add Section & Reset Buttons Row -->
  <div class="flex gap-2.5">
    <button
      id="btn-add-section"
      type="button"
      class="flex-1 bg-success/15 text-success hover:bg-success/25 border border-success/30 font-bold text-xs py-3 rounded-2xl flex items-center justify-center gap-2 cursor-pointer transition-all duration-200 active:scale-[0.99]"
    >
      <Icon name="plus" size={14} />
      <span>Add Section</span>
    </button>
    <button
      id="btn-reset-defaults"
      type="button"
      class="bg-surface-variant/40 text-on-surface-variant hover:text-on-surface border border-outline/15 font-bold text-xs px-4 py-3 rounded-2xl flex items-center justify-center gap-1.5 cursor-pointer transition-all duration-200 active:scale-[0.99]"
      title="Reset sections to default"
    >
      <span>↺ Reset All</span>
    </button>
  </div>

  <!-- Bottom Fixed Action Bar (Cancel / Save) -->
  <div
    class="fixed bottom-6 left-0 right-0 z-20 flex justify-center px-4 pointer-events-none"
  >
    <div
      class="max-w-[420px] w-full bg-surface/90 backdrop-blur-md p-3 rounded-2xl border border-outline/15 shadow-lg flex gap-3 pointer-events-auto"
    >
      <button
        id="btn-cancel-edit"
        type="button"
        class="flex-1 btn btn-outlined text-xs font-bold py-2.5 rounded-xl border-outline/30 text-on-surface hover:bg-surface-variant/20 cursor-pointer transition-all active:scale-95"
      >
        Cancel
      </button>
      <button
        id="btn-save-edit"
        type="button"
        class="flex-1 btn btn-filled text-xs font-bold py-2.5 rounded-xl bg-success text-on-primary hover:bg-success/90 cursor-pointer transition-all active:scale-95 shadow-sm"
      >
        Save
      </button>
    </div>
  </div>

  <!-- Reset Confirmation Modal Dialog (Material Design 3) -->
  <div
    id="modal-reset-confirm"
    class="fixed inset-0 z-50 bg-black/60 backdrop-blur-sm flex items-center justify-center p-4 opacity-0 pointer-events-none transition-opacity duration-200"
    role="dialog"
    aria-modal="true"
  >
    <div
      class="bg-surface rounded-[28px] max-w-[320px] w-full p-6 flex flex-col gap-4 border border-outline/10 shadow-elevation-5 transform scale-95 transition-transform duration-200"
    >
      <div class="flex flex-col gap-1.5 text-center">
        <div
          class="w-10 h-10 rounded-full bg-error/10 text-error flex items-center justify-center mx-auto mb-1"
        >
          <Icon name="notes" size={20} />
        </div>
        <h3 class="text-base font-extrabold text-on-surface">
          Reset All Sections?
        </h3>
        <p class="text-xs text-on-surface-variant leading-relaxed">
          This will revert all intro script sections back to their original
          defaults and discard any custom edits.
        </p>
      </div>

      <div class="flex gap-3 mt-2">
        <button
          id="btn-cancel-reset"
          type="button"
          class="btn btn-outlined flex-1 py-2.5 text-xs font-bold rounded-xl border-outline/30 text-on-surface cursor-pointer"
        >
          Cancel
        </button>
        <button
          id="btn-confirm-reset"
          type="button"
          class="btn btn-filled flex-1 py-2.5 text-xs font-bold rounded-xl bg-error text-white hover:bg-error/90 cursor-pointer shadow-sm"
        >
          Reset All
        </button>
      </div>
    </div>
  </div>

  <!-- Markdown Guide Modal Dialog (Material Design 3) -->
  <div
    id="modal-markdown-guide"
    class="fixed inset-0 z-50 bg-black/60 backdrop-blur-sm flex items-center justify-center p-4 opacity-0 pointer-events-none transition-opacity duration-200"
    role="dialog"
    aria-modal="true"
  >
    <div
      class="bg-surface rounded-[28px] max-w-[340px] w-full p-6 flex flex-col gap-4 border border-outline/10 shadow-elevation-5 transform scale-95 transition-transform duration-200"
    >
      <div class="flex flex-col gap-1 text-center">
        <div
          class="w-10 h-10 rounded-full bg-primary/10 text-primary flex items-center justify-center mx-auto mb-1 text-lg"
        >
          💡
        </div>
        <h3 class="text-base font-extrabold text-on-surface">
          Formatting Shortcuts
        </h3>
        <p class="text-xs text-on-surface-variant">
          Use simple text formatting in your script sections:
        </p>
      </div>

      <div
        class="flex flex-col gap-2.5 bg-surface-variant/30 rounded-2xl p-3.5 border border-outline/10 text-xs"
      >
        <div
          class="flex justify-between items-center pb-2 border-b border-outline/10"
        >
          <span class="font-bold text-on-surface">Bold</span>
          <code
            class="bg-surface px-2 py-0.5 rounded border border-outline/20 font-mono text-[11px] text-primary font-bold"
            >**started**</code
          >
        </div>
        <div
          class="flex justify-between items-center pb-2 border-b border-outline/10"
        >
          <span class="font-bold text-on-surface">Italic</span>
          <code
            class="bg-surface px-2 py-0.5 rounded border border-outline/20 font-mono text-[11px] text-primary font-bold"
            >*important*</code
          >
        </div>
        <div
          class="flex justify-between items-center pb-2 border-b border-outline/10"
        >
          <span class="font-bold text-on-surface">Links</span>
          <code
            class="bg-surface px-2 py-0.5 rounded border border-outline/20 font-mono text-[11px] text-primary font-bold"
            >[Text](url)</code
          >
        </div>
        <div class="flex justify-between items-center">
          <span class="font-bold text-on-surface">Bullet Points</span>
          <code
            class="bg-surface px-2 py-0.5 rounded border border-outline/20 font-mono text-[11px] text-primary font-bold"
            >• item or - item</code
          >
        </div>
      </div>

      <button
        id="btn-close-markdown-guide"
        type="button"
        class="btn btn-filled py-2.5 text-xs font-bold rounded-xl bg-primary text-on-primary hover:bg-primary/90 cursor-pointer shadow-sm w-full mt-1"
      >
        Got it!
      </button>
    </div>
  </div>
</div>
