<!-- About Modal Dialog Overlay -->
<div
  id="about-modal"
  class="fixed inset-0 z-50 bg-black/60 backdrop-blur-sm flex items-center justify-center p-4 opacity-0 pointer-events-none transition-opacity duration-200"
  role="dialog"
  aria-modal="true"
>
  <div
    class="bg-surface rounded-[28px] max-w-[320px] w-full p-6 flex flex-col gap-4 border border-outline/10 shadow-elevation-5 transform scale-95 transition-transform duration-200"
  >
    <!-- Logo & Brand Title -->
    <div class="flex flex-col items-center gap-2 text-center w-full">
      <img
        src="/images/gdg-logo.png"
        alt="GDG Logo"
        class="h-12 w-auto object-contain"
      />
      <h3 class="text-base font-extrabold text-on-surface mt-1">
        GDG Event Companion
      </h3>
      <p class="text-[10px] text-on-surface-variant/80 font-medium">
        Version 1.0.5
      </p>
    </div>

    <!-- Description & Author Details -->
    <div
      class="flex flex-col gap-3 text-xs text-on-surface-variant leading-relaxed"
    >
      <p class="text-center font-medium px-1">
        "Your ultimate companion for accessing community links, projecting QR
        codes, and viewing presentation scripts."
      </p>

      <!-- Buy Me a Coffee Link -->
      <div class="flex justify-center my-0.5">
        <a
          href="https://buymeacoffee.com/codevista"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center justify-center gap-2 bg-[#ffdd00] hover:bg-[#ffea33] text-black font-black text-[11px] py-2 px-5 rounded-full shadow-sm hover:shadow transition-all duration-200 select-none border border-black/5"
        >
          <span>☕</span> Buy me a coffee
        </a>
      </div>

      <div class="border-t border-outline/10 pt-3 flex flex-col gap-1.5">
        <div class="flex justify-between items-center text-[11px]">
          <span class="font-bold text-on-surface">Made by:</span>
          <a
            href="https://techno-logic.us/"
            target="_blank"
            rel="noopener noreferrer"
            class="font-black text-primary hover:underline">Javi</a
          >
        </div>
        <div class="flex justify-between items-center text-[11px]">
          <span class="font-bold text-on-surface">Built for:</span>
          <span class="font-semibold">GDG Organizers</span>
        </div>
        <div class="flex justify-between items-center text-[11px]">
          <span class="font-bold text-on-surface">Framework:</span>
          <span class="font-black text-primary">Astro</span>
        </div>
        <div class="flex justify-between items-center text-[11px]">
          <span class="font-bold text-on-surface">Design System:</span>
          <span class="font-semibold text-on-surface-variant"
            >Material Design 3</span
          >
        </div>
      </div>
    </div>

    <button
      id="about-close"
      class="btn btn-filled w-full py-2.5 text-xs font-bold mt-2 cursor-pointer"
    >
      Close
    </button>
  </div>
</div>

<script>
  const aboutBtn = document.getElementById('about-btn');
  const aboutModal = document.getElementById('about-modal');
  const aboutClose = document.getElementById('about-close');

  if (aboutBtn && aboutModal && aboutClose) {
    aboutBtn.addEventListener('click', () => {
      aboutModal.classList.remove('opacity-0', 'pointer-events-none');
      aboutModal.firstElementChild?.classList.remove('scale-95');
      aboutModal.firstElementChild?.classList.add('scale-100');
    });

    const closeAbout = () => {
      aboutModal.classList.add('opacity-0', 'pointer-events-none');
      aboutModal.firstElementChild?.classList.remove('scale-100');
      aboutModal.firstElementChild?.classList.add('scale-95');
    };

    aboutClose.addEventListener('click', closeAbout);
    aboutModal.addEventListener('click', (e) => {
      if (e.target === aboutModal) closeAbout();
    });
  }
</script>
