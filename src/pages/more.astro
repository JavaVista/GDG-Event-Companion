---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
import { THEMES } from '../config/themes';
---

<BaseLayout
  title="Settings & Tools | GDG Event Companion"
  description="Manage app active theme and access organizer tools"
>
  <div class="flex flex-col gap-6 py-2">
    <!-- Header/Introduction -->
    <div class="flex flex-col gap-1">
      <h2 class="text-xl font-bold flex items-center gap-1.5 animate-fade-in">
        More Options
      </h2>
      <p class="text-xs text-on-surface-variant">
        Configure application settings and access organizer utilities.
      </p>
    </div>

    <!-- 1. Organizer Portal Card -->
    <div
      class="card card-outlined border-outline/25 p-4 flex flex-col gap-3 bg-surface/50 rounded-[24px]"
    >
      <div class="flex justify-between items-center w-full">
        <div class="flex items-center gap-2.5 min-w-0">
          <div
            class="w-8 h-8 rounded-lg bg-secondary/10 text-secondary flex items-center justify-center shrink-0"
          >
            <Icon name="organizer" size={16} />
          </div>
          <div class="flex flex-col min-w-0 pr-4">
            <span class="text-xs font-bold text-on-surface"
              >Organizer Tools Dashboard</span
            >
            <span
              class="text-[11px] text-on-surface-variant"
              id="organizer-status-desc"
            >
              Check authorization status...
            </span>
          </div>
        </div>

        <div class="flex gap-2 items-center shrink-0">
          <button
            id="more-lock-btn"
            class="btn btn-text text-error text-[11px] py-1.5 px-3 border border-error/20 hover:bg-error/5 rounded-full shrink-0 cursor-pointer"
            style="display: none;"
          >
            Lock
          </button>
          <a
            id="organizer-action-btn"
            href="/organizer"
            class="btn btn-filled text-xs py-1.5 px-4 cursor-pointer"
          >
            Unlock
          </a>
        </div>
      </div>
    </div>

    <!-- 2. Settings Theme Selector Card -->
    <div
      class="card card-outlined border-outline/25 p-4 flex flex-col gap-3 bg-surface/50 rounded-[24px]"
    >
      <div class="flex justify-between items-center w-full">
        <div class="flex items-center gap-2.5 min-w-0">
          <div
            class="w-8 h-8 rounded-lg bg-primary/10 text-primary flex items-center justify-center shrink-0"
          >
            <Icon name="theme" size={16} />
          </div>
          <div class="flex flex-col min-w-0 pr-4">
            <span class="text-xs font-bold text-on-surface"
              >App Active Theme</span
            >
            <span class="text-[11px] text-on-surface-variant">
              Switch event visual styles instantly
            </span>
          </div>
        </div>

        <select
          id="shell-theme-select-more"
          class="select-theme bg-surface-variant text-on-surface-variant text-xs font-semibold py-1.5 px-3 pr-7 rounded-full border border-outline hover:border-primary transition-all duration-200 cursor-pointer focus:outline-none appearance-none shrink-0"
          aria-label="Select Theme"
        >
          {
            THEMES.map((theme) => (
              <option value={theme.id}>
                {theme.id === 'gdg-default'
                  ? 'Default'
                  : theme.id === 'gdg-devfest'
                    ? 'DevFest'
                    : 'Holiday'}
              </option>
            ))
          }
        </select>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  import { getActiveTheme, setActiveThemeId } from '../config/themes';
  import { isUnlocked, lock } from '../lib/organizer-auth';

  const statusDesc = document.getElementById('organizer-status-desc');
  const actionBtn = document.getElementById(
    'organizer-action-btn'
  ) as HTMLAnchorElement;
  const lockBtn = document.getElementById('more-lock-btn');
  const themeSelect = document.getElementById(
    'shell-theme-select-more'
  ) as HTMLSelectElement;

  // 1. Live status checks
  const updateOrganizerUI = () => {
    if (!statusDesc || !actionBtn || !lockBtn) return;

    if (isUnlocked()) {
      statusDesc.textContent = 'Access scripts and presenter tools';
      actionBtn.textContent = 'Dashboard';
      actionBtn.setAttribute('href', '/organizer/dashboard');
      lockBtn.style.display = 'inline-flex';
    } else {
      statusDesc.textContent = 'Access locked for community organizers only';
      actionBtn.textContent = 'Unlock';
      actionBtn.setAttribute('href', '/organizer');
      lockBtn.style.display = 'none';
    }
  };

  updateOrganizerUI();

  if (lockBtn) {
    lockBtn.addEventListener('click', () => {
      lock();
      updateOrganizerUI();
    });
  }

  // 2. Settings Theme Selector logic
  if (themeSelect) {
    themeSelect.value = getActiveTheme().id;

    themeSelect.addEventListener('change', (e) => {
      const selectedId = (e.target as HTMLSelectElement).value;
      setActiveThemeId(selectedId);
    });

    window.addEventListener('storage', (e) => {
      if (e.key === 'gdg-active-theme-config-id') {
        themeSelect.value = getActiveTheme().id;
      }
      if (e.key === 'gdg-organizer-unlocked') {
        updateOrganizerUI();
      }
    });
  }
</script>
