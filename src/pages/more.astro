---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
import { THEMES } from '../config/themes';
---

<BaseLayout
  title="Organizer Portal | GDG Event Companion"
  description="Manage event presenter scripts and dashboard"
>
  <!-- 1. LOCKED VIEW: Enter Organizer Code -->
  <div
    id="unlock-container"
    class="flex flex-col items-center gap-6 py-6 text-center transition-opacity duration-300"
  >
    <div class="flex flex-col items-center gap-2">
      <!-- Lock Avatar -->
      <div
        class="w-16 h-16 rounded-full bg-primary/10 text-primary flex items-center justify-center relative overflow-hidden group"
      >
        <Icon name="lock" size={32} class="animate-pulse" />
      </div>
      <h2 class="text-xl font-bold mt-2">Unlock Organizer Mode</h2>
      <p class="text-xs text-on-surface-variant max-w-xs leading-relaxed">
        Organizer tools and presenter scripts live here. Unlocked with your
        secret team credentials.
      </p>
    </div>

    <!-- Code Input Card -->
    <div
      class="card card-elevated p-6 flex flex-col items-stretch gap-4 bg-surface max-w-[280px] w-full border border-outline/10 shadow-elevation-2 rounded-[24px]"
    >
      <div class="flex flex-col gap-1 text-left">
        <label
          for="organizer-code"
          class="text-[12px] text-on-surface-variant font-bold uppercase tracking-wider"
        >
          Enter Organizer Code
        </label>
        <input
          type="text"
          id="organizer-code"
          placeholder="Enter code here"
          class="w-full bg-surface-variant text-on-surface text-sm font-semibold py-2.5 px-4 rounded-xl border border-outline focus:border-primary focus:ring-1 focus:ring-primary focus:outline-none transition-all duration-200"
        />
      </div>

      <button
        id="unlock-btn"
        class="btn btn-filled text-xs py-2.5 shadow-elevation-1 w-full cursor-pointer"
      >
        <Icon name="lock" size={16} />
        Unlock Dashboard
      </button>

      <span id="error-msg" class="text-[12px] text-error font-semibold hidden">
        ❌ Incorrect code!
      </span>
    </div>

    <p class="text-[12px] text-on-surface-variant/70 font-medium">
      Not an organizer? Enjoy the event!
    </p>
  </div>

  <!-- 2. UNLOCKED VIEW: Organizer Dashboard -->
  <div
    id="dashboard-container"
    class="flex flex-col gap-5 py-2 hidden transition-opacity duration-300"
  >
    <div class="flex justify-between items-start gap-4">
      <div class="flex flex-col gap-1">
        <h2 class="text-xl font-bold flex items-center gap-1.5">
          Organizer Dashboard
          <span
            class="text-[11px] font-bold bg-secondary/15 text-secondary px-2.5 py-0.5 rounded-full border border-secondary/20 uppercase tracking-wide"
          >
            Unlocked
          </span>
        </h2>
        <p class="text-xs text-on-surface-variant">
          Quick access to scripts and event management tools.
        </p>
      </div>

      <button
        id="lock-btn"
        class="btn btn-text text-error text-[11px] py-1.5 px-3 border border-error/20 hover:bg-error/5 rounded-full shrink-0 cursor-pointer"
      >
        Lock Portal
      </button>
    </div>

    <!-- Dashboard Tools Grid -->
    <div class="grid grid-cols-2 gap-3.5 mt-2">
      <!-- 1. Current Event -->
      <div
        class="card card-outlined border-outline/25 p-3 flex flex-col justify-between gap-4 bg-surface/40 hover:border-primary/50 cursor-pointer group transition-colors duration-200 rounded-2xl"
      >
        <div
          class="w-8 h-8 rounded-lg bg-primary/10 text-primary flex items-center justify-center shrink-0 animate-pulse"
        >
          <Icon name="calendar" size={16} />
        </div>
        <div>
          <h3 class="text-xs font-bold text-on-surface">Current Event</h3>
          <p class="text-[11px] text-on-surface-variant mt-0.5 leading-tight">
            View & edit event details
          </p>
        </div>
      </div>

      <!-- 2. Intro Script -->
      <div
        class="card card-outlined border-outline/25 p-3 flex flex-col justify-between gap-4 bg-surface/40 hover:border-primary/50 cursor-pointer group transition-colors duration-200 rounded-2xl"
      >
        <div
          class="w-8 h-8 rounded-lg bg-secondary/10 text-secondary flex items-center justify-center shrink-0"
        >
          <Icon name="notes" size={16} />
        </div>
        <div>
          <h3 class="text-xs font-bold text-on-surface">Intro Script</h3>
          <p class="text-[11px] text-on-surface-variant mt-0.5 leading-tight">
            Read / edit intro script
          </p>
        </div>
      </div>

      <!-- 3. Outro Script -->
      <div
        class="card card-outlined border-outline/25 p-3 flex flex-col justify-between gap-4 bg-surface/40 hover:border-primary/50 cursor-pointer group transition-colors duration-200 rounded-2xl"
      >
        <div
          class="w-8 h-8 rounded-lg bg-secondary/10 text-secondary flex items-center justify-center shrink-0"
        >
          <Icon name="notes" size={16} />
        </div>
        <div>
          <h3 class="text-xs font-bold text-on-surface">Outro Script</h3>
          <p class="text-[11px] text-on-surface-variant mt-0.5 leading-tight">
            Read / edit outro script
          </p>
        </div>
      </div>

      <!-- 4. QR Center -->
      <a
        href="/qr"
        class="card card-outlined border-outline/25 p-3 flex flex-col justify-between gap-4 bg-surface/40 hover:border-primary/50 cursor-pointer group transition-colors duration-200 rounded-2xl"
      >
        <div
          class="w-8 h-8 rounded-lg bg-tertiary/10 text-tertiary flex items-center justify-center shrink-0"
        >
          <Icon name="qr" size={16} />
        </div>
        <div>
          <h3 class="text-xs font-bold text-on-surface">QR Center</h3>
          <p class="text-[11px] text-on-surface-variant mt-0.5 leading-tight">
            Show QR codes
          </p>
        </div>
      </a>

      <!-- 5. Speaker -->
      <div
        class="card card-outlined border-outline/25 p-3 flex flex-col justify-between gap-4 bg-surface/40 hover:border-primary/50 cursor-pointer group transition-colors duration-200 rounded-2xl"
      >
        <div
          class="w-8 h-8 rounded-lg bg-primary/10 text-primary flex items-center justify-center shrink-0"
        >
          <Icon name="speaker" size={16} />
        </div>
        <div>
          <h3 class="text-xs font-bold text-on-surface">Speaker</h3>
          <p class="text-[11px] text-on-surface-variant mt-0.5 leading-tight">
            Speaker info & links
          </p>
        </div>
      </div>

      <!-- 6. Venue -->
      <div
        class="card card-outlined border-outline/25 p-3 flex flex-col justify-between gap-4 bg-surface/40 hover:border-primary/50 cursor-pointer group transition-colors duration-200 rounded-2xl"
      >
        <div
          class="w-8 h-8 rounded-lg bg-secondary/10 text-secondary flex items-center justify-center shrink-0"
        >
          <Icon name="venue" size={16} />
        </div>
        <div>
          <h3 class="text-xs font-bold text-on-surface">Venue</h3>
          <p class="text-[11px] text-on-surface-variant mt-0.5 leading-tight">
            Venue details
          </p>
        </div>
      </div>

      <!-- 7. Notes -->
      <div
        class="card card-outlined border-outline/25 p-3 flex flex-col justify-between gap-4 bg-surface/40 hover:border-primary/50 cursor-pointer group transition-colors duration-200 rounded-2xl"
      >
        <div
          class="w-8 h-8 rounded-lg bg-tertiary/10 text-tertiary flex items-center justify-center shrink-0"
        >
          <Icon name="notes" size={16} />
        </div>
        <div>
          <h3 class="text-xs font-bold text-on-surface">Notes</h3>
          <p class="text-[11px] text-on-surface-variant mt-0.5 leading-tight">
            Organizer notes
          </p>
        </div>
      </div>

      <!-- 8. Event Checklist -->
      <div
        class="card card-outlined border-outline/25 p-3 flex flex-col justify-between gap-4 bg-surface/40 hover:border-primary/50 cursor-pointer group transition-colors duration-200 rounded-2xl"
      >
        <div
          class="w-8 h-8 rounded-lg bg-error/10 text-error flex items-center justify-center shrink-0"
        >
          <Icon name="checklist" size={16} />
        </div>
        <div>
          <h3 class="text-xs font-bold text-on-surface">Event Checklist</h3>
          <p class="text-[11px] text-on-surface-variant mt-0.5 leading-tight">
            Event checklist
          </p>
        </div>
      </div>
    </div>
  </div>

  <!-- 3. ALWAYS VISIBLE: Settings Section (Theme Selector Card) -->
  <div
    class="card card-outlined border-outline/25 p-4 flex flex-col gap-3 bg-surface/50 mt-1 rounded-[24px]"
  >
    <div class="flex justify-between items-center w-full">
      <div class="flex items-center gap-2.5">
        <div
          class="w-8 h-8 rounded-lg bg-primary/10 text-primary flex items-center justify-center shrink-0"
        >
          <Icon name="theme" size={16} />
        </div>
        <div class="flex flex-col">
          <span class="text-xs font-bold text-on-surface">App Active Theme</span
          >
          <span class="text-[11px] text-on-surface-variant"
            >Switch event visual styles instantly</span
          >
        </div>
      </div>

      <select
        id="shell-theme-select-more"
        class="select-theme bg-surface-variant text-on-surface-variant text-xs font-semibold py-1.5 px-3 pr-7 rounded-full border border-outline hover:border-primary transition-all duration-200 cursor-pointer focus:outline-none appearance-none"
        aria-label="Select Theme"
      >
        {
          THEMES.map((theme) => (
            <option value={theme.id}>
              {theme.id === 'gdg-default'
                ? 'Default'
                : theme.id === 'gdg-devfest'
                  ? 'DevFest'
                  : 'Holiday'}
            </option>
          ))
        }
      </select>
    </div>
  </div>
</BaseLayout>

<script>
  import { getActiveTheme, setActiveThemeId } from '../config/themes';

  const unlockContainer = document.getElementById('unlock-container');
  const dashboardContainer = document.getElementById('dashboard-container');
  const codeInput = document.getElementById(
    'organizer-code'
  ) as HTMLInputElement;
  const unlockBtn = document.getElementById('unlock-btn');
  const lockBtn = document.getElementById('lock-btn');
  const errorMsg = document.getElementById('error-msg');
  const themeSelect = document.getElementById(
    'shell-theme-select-more'
  ) as HTMLSelectElement;

  // 1. Organizer Mode Toggle logic
  const checkUnlockedState = () => {
    if (sessionStorage.getItem('gdg-organizer-unlocked') === 'true') {
      unlockContainer?.classList.add('hidden');
      dashboardContainer?.classList.remove('hidden');
    } else {
      unlockContainer?.classList.remove('hidden');
      dashboardContainer?.classList.add('hidden');
    }
  };

  checkUnlockedState();

  if (unlockBtn && codeInput && errorMsg) {
    unlockBtn.addEventListener('click', () => {
      const code = codeInput.value.trim().toLowerCase();
      if (code === 'gdg') {
        sessionStorage.setItem('gdg-organizer-unlocked', 'true');
        errorMsg.classList.add('hidden');
        codeInput.value = '';
        checkUnlockedState();
      } else {
        errorMsg.classList.remove('hidden');
      }
    });

    codeInput.addEventListener('keypress', (e) => {
      if (e.key === 'Enter') unlockBtn.click();
    });
  }

  if (lockBtn) {
    lockBtn.addEventListener('click', () => {
      sessionStorage.removeItem('gdg-organizer-unlocked');
      checkUnlockedState();
    });
  }

  // 2. Settings Theme Selector logic
  if (themeSelect) {
    themeSelect.value = getActiveTheme().id;

    themeSelect.addEventListener('change', (e) => {
      const selectedId = (e.target as HTMLSelectElement).value;
      setActiveThemeId(selectedId);
    });

    window.addEventListener('storage', (e) => {
      if (e.key === 'gdg-active-theme-config-id') {
        themeSelect.value = getActiveTheme().id;
      }
    });
  }
</script>
