---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
import { PUBLIC_LINKS } from '../config/links';
import {
  fetchChapterEvents,
  getLiveOrNextEvent,
  getUpcomingEvents,
} from '../lib/bevy';

const allEvents = await fetchChapterEvents(920);
const currentEvent = getLiveOrNextEvent(allEvents);
const upcomingEvents = getUpcomingEvents(allEvents);

const getSpeakerDetails = (eventTitle: string) => {
  if (eventTitle.includes('AI Honesty')) {
    return {
      name: 'Muntaser Syed',
      avatar:
        'https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?auto=format&fit=crop&q=80&w=120',
    };
  }
  return {
    name: 'GDG Speaker',
    avatar: '/images/gdg-logo.png',
  };
};

const calculateDaysRemaining = (startDateString: string) => {
  const diffTime = new Date(startDateString).getTime() - new Date().getTime();
  const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
  return diffDays > 0 ? diffDays : 0;
};

const getColorClasses = (colorToken: string) => {
  switch (colorToken) {
    case 'primary':
      return 'bg-[#4285f4] text-white'; // Google Blue
    case 'secondary':
      return 'bg-[#34a853] text-white'; // Google Green
    case 'accent':
      return 'bg-[#f9ab00] text-white'; // Google Yellow/Gold (White text/icon)
    case 'error':
      return 'bg-[#ea4335] text-white'; // Google Red
    case 'success':
      return 'bg-[#34a853] text-white'; // Google Green (Success)
    case 'purple':
      return 'bg-[#a142f4] text-white'; // Purple brand color
    default:
      return 'bg-surface-variant text-on-surface-variant';
  }
};
---

<BaseLayout title="Home | GDG Event Companion">
  <!-- Top Greeting & Skyline Hero Banner -->
  <div
    class="relative -mx-4 px-4 pt-5 pb-28 overflow-hidden bg-gradient-to-b from-[#4285f4]/8 via-[#4285f4]/2 to-transparent"
  >
    <!-- Orlando Skyline absolute positioned in the background -->
    <div class="absolute inset-0 z-0 pointer-events-none select-none">
      <img
        src="/images/orlando-skyline.png"
        alt="Orlando Skyline"
        class="w-full h-full object-cover object-center opacity-100 dark:opacity-40"
      />
      <!-- Gentle mask to blend the skyline bottom with the page -->
      <div
        class="absolute inset-x-0 bottom-0 h-8 bg-gradient-to-t from-background to-transparent"
      >
      </div>
    </div>

    <!-- Welcome Text (z-10 above the background image) -->
    <div class="relative z-10 flex flex-col">
      <h2
        class="text-[18px] font-black tracking-tight flex items-center gap-1.5 text-on-background"
      >
        Hola, Organizer! <span class="animate-bounce">👋</span>
      </h2>
      <p class="text-[12px] text-on-surface-variant font-medium mt-0.5">
        Welcome to your event companion.
      </p>
    </div>
  </div>

  <!-- Hero Event Card -->
  {
    currentEvent ? (
      <div class="card card-elevated p-0 overflow-hidden border border-outline/10 flex flex-col bg-surface shadow-elevation-2 rounded-[24px] transition-all duration-300 mt-[-32px] z-10 relative">
        {/* Simple card header bar (Calendar + Live Tag) */}
        <div class="px-4.5 pt-4 pb-2.5 flex justify-between items-center bg-surface border-b border-outline/5">
          <div class="flex items-center gap-1.5 text-primary font-bold text-[11px] tracking-wider uppercase">
            <Icon name="calendar" size={16} class="text-primary" />
            {currentEvent.cardLabel}
          </div>
          <span class="text-[10px] font-black bg-secondary text-white px-2.5 py-0.5 rounded-full border border-white/20 animate-pulse tracking-wider uppercase">
            {currentEvent.statusLabel}
          </span>
        </div>

        {/* Card Details Area */}
        <div class="p-4.5 flex justify-between items-center gap-4 bg-surface">
          <div class="flex flex-col gap-1.5 max-w-[72%]">
            <h3 class="text-[15px] font-extrabold leading-tight text-on-surface">
              {currentEvent.title}
            </h3>
            <p class="text-[12px] text-on-surface-variant font-medium leading-normal mt-0.5">
              {currentEvent.descriptionShort}
            </p>

            {/* Details Grid */}
            <div class="flex flex-col gap-1 border-t border-outline/5 pt-2.5 mt-1">
              <div class="flex items-center gap-1.5 text-[11px] text-on-surface-variant/80 font-medium">
                <span>📅 {currentEvent.displayDate}</span>
                <span class="opacity-30">•</span>
                <span>⏰ {currentEvent.displayTime}</span>
              </div>
              <div class="flex items-center gap-1 text-[11px] text-on-surface-variant font-semibold">
                <span>📍 {currentEvent.displayLocation}</span>
              </div>
            </div>
          </div>

          {/* Speaker Avatar Circular Image on Right */}
          {(() => {
            const speaker = getSpeakerDetails(currentEvent.title);
            return (
              <div class="flex flex-col items-center shrink-0">
                <div class="w-13 h-13 rounded-full border-2 border-primary/25 overflow-hidden shadow-elevation-1 bg-surface-variant">
                  <img
                    src={speaker.avatar}
                    alt={speaker.name}
                    class="w-full h-full object-cover"
                  />
                </div>
              </div>
            );
          })()}
        </div>
      </div>
    ) : (
      <div class="card card-elevated p-6 flex flex-col items-center text-center border border-outline/10 bg-surface shadow-elevation-2 rounded-[24px] transition-all duration-300 mt-[-32px] z-10 relative gap-2">
        <div class="w-12 h-12 rounded-full bg-surface-variant flex items-center justify-center text-on-surface-variant">
          <Icon name="calendar" size={22} />
        </div>
        <h3 class="text-sm font-bold text-on-surface mt-1">No Active Event</h3>
        <p class="text-[12px] text-on-surface-variant/80 font-medium px-4">
          There are no sessions in progress right now. Check back later!
        </p>
      </div>
    )
  }

  <!-- Upcoming Events Section -->
  <div class="flex flex-col gap-2 mt-1">
    <div class="flex justify-between items-center">
      <h3
        class="text-[12px] font-bold uppercase text-on-surface-variant tracking-wider"
      >
        Upcoming Events
      </h3>
      <a
        href="/events"
        class="text-[12px] font-bold text-primary hover:underline">View all</a
      >
    </div>

    {
      upcomingEvents.length > 0 ? (
        upcomingEvents.map((event) => {
          const dateParts = event.displayDate.split(' ');
          const month = dateParts[0] || 'Jun';
          const day = dateParts[1]?.replace(',', '') || '27';
          const daysRemaining = calculateDaysRemaining(event.startDate);
          return (
            <a
              href="/events"
              class="card card-outlined border-outline/25 p-3 flex items-center justify-between gap-3 bg-surface/40 hover:border-primary/50 transition-colors duration-150 rounded-2xl"
            >
              <div class="flex items-center gap-3">
                <div class="w-12 h-12 rounded-xl bg-primary text-on-primary flex flex-col items-center justify-center shrink-0 shadow-elevation-1">
                  <span class="text-[10px] font-black uppercase tracking-wide leading-none">
                    {month}
                  </span>
                  <span class="text-[15px] font-black leading-none mt-0.5">
                    {day}
                  </span>
                </div>

                <div class="flex flex-col gap-0.5 max-w-[170px]">
                  <h4 class="text-[13px] font-black text-on-surface truncate leading-tight">
                    {event.title}
                  </h4>
                  <span class="text-[11px] text-on-surface-variant font-semibold">
                    {event.audienceType.replace('_', ' ')}
                  </span>
                  <span class="text-[11px] text-on-surface-variant/80 font-medium flex items-center gap-0.5 mt-0.5">
                    📍 {event.displayLocation}
                  </span>
                </div>
              </div>

              <div class="flex items-center gap-2 shrink-0">
                <div class="flex flex-col items-end leading-none">
                  <span class="text-sm font-black text-primary">
                    {daysRemaining}
                  </span>
                  <span class="text-[9px] font-bold text-on-surface-variant uppercase mt-0.5">
                    Days
                  </span>
                </div>
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="w-3.5 h-3.5 text-on-surface-variant/60"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2.5"
                >
                  <polyline points="9 18 15 12 9 6" />
                </svg>
              </div>
            </a>
          );
        })
      ) : (
        <div class="card card-outlined border-outline/25 p-5 flex flex-col items-center text-center justify-center gap-1.5 bg-surface/30 rounded-2xl">
          <span class="text-[12px] font-bold text-on-surface">
            No Upcoming Events
          </span>
          <span class="text-[11px] text-on-surface-variant/80 font-medium">
            Check back later for new workshops and meetups!
          </span>
        </div>
      )
    }

    <!-- Carousel Dot Indicators (Matching panel 1 prototype, shifted to upcoming events) -->
    <div class="flex justify-center gap-1.5 mt-1">
      <span class="w-1.5 h-1.5 rounded-full bg-primary transition-all"></span>
      <span class="w-1.5 h-1.5 rounded-full bg-outline-variant/60"></span>
      <span class="w-1.5 h-1.5 rounded-full bg-outline-variant/60"></span>
    </div>
  </div>

  <!-- Quick Links Grid (Matching panel 1 prototype with bright solid background, 3 columns, vertical stack with white text/icons) -->
  <div class="flex flex-col gap-2 mt-1">
    <div class="flex justify-between items-center">
      <h3
        class="text-[12px] text-on-surface-variant font-bold uppercase tracking-wider"
      >
        Quick Links
      </h3>
      <span
        class="text-[12px] font-bold text-primary cursor-pointer hover:underline"
        >Edit</span
      >
    </div>
    <div class="grid grid-cols-3 gap-3">
      {
        PUBLIC_LINKS.map((link) => (
          <a
            href={link.url}
            target={link.isExternal ? '_blank' : undefined}
            rel={link.isExternal ? 'noopener noreferrer' : undefined}
            class={`flex flex-col items-center justify-center text-center gap-2 py-4 px-1.5 rounded-[20px] shadow-elevation-1 transition-all duration-200 hover:-translate-y-0.5 active:translate-y-0 hover:shadow-elevation-2 min-h-[96px] ${getColorClasses(link.colorToken)}`}
          >
            <Icon name={link.icon} size={28} class="shrink-0" />
            <span class="text-[11px] font-extrabold tracking-wide leading-tight break-words w-full px-0.5">
              {link.title}
            </span>
          </a>
        ))
      }
    </div>
  </div>

  <!-- Organizer Tools Gate -->
  <a
    href="/more"
    class="card card-outlined border-outline/25 p-3.5 flex items-center justify-between hover:bg-surface-variant/10 cursor-pointer transition-colors duration-150 mt-1 rounded-2xl"
  >
    <div class="flex items-center gap-3">
      <Icon name="lock" size={18} class="text-primary shrink-0" />
      <div class="flex flex-col">
        <span class="text-[13px] font-bold text-on-surface"
          >Organizer Tools</span
        >
        <span class="text-[11px] text-on-surface-variant mt-0.5"
          >Enter code to access presenter scripts</span
        >
      </div>
    </div>
    <svg
      xmlns="http://www.w3.org/2000/svg"
      class="w-3.5 h-3.5 text-on-surface-variant/60"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
      stroke-width="2.5"
    >
      <polyline points="9 18 15 12 9 6"></polyline>
    </svg>
  </a>
</BaseLayout>
