---
import BaseLayout from '../../layouts/BaseLayout.astro';
import OrganizerDashboardGrid from '../../components/OrganizerDashboardGrid.astro';
import { fetchBevyEvents } from '../../services/bevy-events-service';
import { getLiveOrNextEvent } from '../../lib/bevy';

const allEvents = await fetchBevyEvents().catch(() => []);
const currentEvent = getLiveOrNextEvent(allEvents);

const currentIndex = currentEvent
  ? allEvents.findIndex((e) => e.id === currentEvent.id)
  : -1;
const nextEvent =
  currentIndex !== -1 && currentIndex + 1 < allEvents.length
    ? allEvents[currentIndex + 1]
    : undefined;
---

<BaseLayout
  title="Organizer Dashboard | GDG Event Companion"
  description="Quick access to scripts and event management tools"
>
  <div
    id="dashboard-container"
    class="flex flex-col gap-5 py-2"
    data-current-event={JSON.stringify(currentEvent)}
    data-next-event={JSON.stringify(nextEvent)}
  >
    <div class="flex flex-col gap-2">
      <!-- Title & CTA Row -->
      <div class="flex justify-between items-center gap-4 w-full">
        <h2 class="text-xl font-bold text-on-surface">Organizer Dashboard</h2>
        <button
          id="lock-btn"
          class="btn btn-text text-error text-[11px] py-1.5 px-3 border border-error/20 hover:bg-error/5 rounded-full shrink-0 cursor-pointer"
        >
          Lock Dashboard
        </button>
      </div>

      <!-- Status Pill & Description -->
      <div class="flex flex-col gap-1.5">
        <div>
          <span
            class="inline-flex text-[10px] font-bold bg-secondary/15 text-secondary px-2.5 py-0.5 rounded-full border border-secondary/20 uppercase tracking-wide animate-pulse"
          >
            Unlocked
          </span>
        </div>
        <p class="text-xs text-on-surface-variant">
          Quick access to scripts and event management tools.
        </p>
      </div>
    </div>

    <!-- Dashboard Tools Grid Component -->
    <OrganizerDashboardGrid />
  </div>

  <!-- MODALS SYSTEM OVERLAYS -->

  <!-- 1. Intro Script Modal -->
  <div
    id="modal-intro-script"
    class="fixed inset-0 z-50 bg-black/60 backdrop-blur-sm flex items-center justify-center p-4 opacity-0 pointer-events-none transition-opacity duration-200"
    role="dialog"
    aria-modal="true"
  >
    <div
      class="bg-surface rounded-[28px] max-w-[340px] w-full p-6 flex flex-col gap-4 border border-outline/10 shadow-elevation-5 transform scale-95 transition-transform duration-200"
    >
      <div class="flex flex-col gap-1">
        <h3 class="text-base font-extrabold text-on-surface">
          Presenter Intro Script
        </h3>
        <p class="text-[10px] text-on-surface-variant/80 font-medium">
          Read at start of event
        </p>
      </div>
      <div
        class="bg-surface-variant/40 border border-outline/5 rounded-2xl p-4"
      >
        <p
          id="intro-text"
          class="text-xs text-on-surface leading-relaxed font-medium"
        >
          "Welcome everyone to today's Google Developer Groups event! We are
          thrilled to have you here in Orlando. A special thank you to our
          speaker Muntaser Syed for joining us to present 'Making AI Honesty
          Machine-Readable'. Remember to scan the QR code to join our Discord
          community, and check out our upcoming schedule. If you'd like to see
          any QR codes or links later, just let me know and I can display them
          for you. Let's get started!"
        </p>
      </div>
      <div class="flex gap-3.5 mt-2">
        <button
          data-copy-target="intro-text"
          class="btn btn-outlined flex-1 py-2 text-xs font-bold cursor-pointer"
        >
          Copy Script
        </button>
        <button
          data-modal-close
          class="btn btn-filled flex-1 py-2 text-xs font-bold cursor-pointer"
        >
          Close
        </button>
      </div>
    </div>
  </div>

  <!-- 2. Outro Script Modal -->
  <div
    id="modal-outro-script"
    class="fixed inset-0 z-50 bg-black/60 backdrop-blur-sm flex items-center justify-center p-4 opacity-0 pointer-events-none transition-opacity duration-200"
    role="dialog"
    aria-modal="true"
  >
    <div
      class="bg-surface rounded-[28px] max-w-[340px] w-full p-6 flex flex-col gap-4 border border-outline/10 shadow-elevation-5 transform scale-95 transition-transform duration-200"
    >
      <div class="flex flex-col gap-1">
        <h3 class="text-base font-extrabold text-on-surface">
          Presenter Outro Script
        </h3>
        <p class="text-[10px] text-on-surface-variant/80 font-medium">
          Read at conclusion of event
        </p>
      </div>
      <div
        class="bg-surface-variant/40 border border-outline/5 rounded-2xl p-4"
      >
        <p
          id="outro-text"
          class="text-xs text-on-surface leading-relaxed font-medium"
        >
          "Thank you all for joining us today! We hope you enjoyed the workshop
          on AI Honesty. Huge thanks again to Muntaser Syed. Please take a
          moment to join our Discord if you haven't yet, and keep an eye on our
          next event 'Build with AI: Gemini on Firebase' on June 27. Enjoy the
          networking session and have a safe trip home!"
        </p>
      </div>
      <div class="flex gap-3.5 mt-2">
        <button
          data-copy-target="outro-text"
          class="btn btn-outlined flex-1 py-2 text-xs font-bold cursor-pointer"
        >
          Copy Script
        </button>
        <button
          data-modal-close
          class="btn btn-filled flex-1 py-2 text-xs font-bold cursor-pointer"
        >
          Close
        </button>
      </div>
    </div>
  </div>

  <!-- 3. Speaker Modal -->
  <div
    id="modal-speaker"
    class="fixed inset-0 z-50 bg-black/60 backdrop-blur-sm flex items-center justify-center p-4 opacity-0 pointer-events-none transition-opacity duration-200"
    role="dialog"
    aria-modal="true"
  >
    <div
      class="bg-surface rounded-[28px] max-w-[340px] w-full p-6 flex flex-col gap-4 border border-outline/10 shadow-elevation-5 transform scale-95 transition-transform duration-200"
    >
      <div class="flex flex-col gap-1">
        <h3 class="text-base font-extrabold text-on-surface">
          Speaker Profile
        </h3>
        <p class="text-[10px] text-on-surface-variant/80 font-medium">
          Speaker spotlight details
        </p>
      </div>
      <div
        class="flex flex-col gap-3 bg-surface-variant/40 border border-outline/5 rounded-2xl p-4 text-xs font-medium"
      >
        <div class="flex justify-between border-b border-outline/5 pb-2">
          <span class="text-on-surface-variant">Speaker:</span>
          <span class="text-on-surface font-bold">Muntaser Syed</span>
        </div>
        <div class="flex flex-col gap-1 border-b border-outline/5 pb-2">
          <span class="text-on-surface-variant">Bio:</span>
          <span class="text-on-surface font-normal leading-normal"
            >AI safety researcher and developer advocate specializing in
            machine-readable integrity models.</span
          >
        </div>
        <div class="flex justify-between border-b border-outline/5 pb-2">
          <span class="text-on-surface-variant">Social Links:</span>
          <a href="https://MuntaserSyed" class="text-primary font-bold"
            >@MuntaserSyed</a
          >
        </div>
      </div>
      <button
        data-modal-close
        class="btn btn-filled w-full py-2.5 text-xs font-bold cursor-pointer mt-1"
      >
        Close
      </button>
    </div>
  </div>

  <!-- 4. Venue Modal -->
  <div
    id="modal-venue"
    class="fixed inset-0 z-50 bg-black/60 backdrop-blur-sm flex items-center justify-center p-4 opacity-0 pointer-events-none transition-opacity duration-200"
    role="dialog"
    aria-modal="true"
  >
    <div
      class="bg-surface rounded-[28px] max-w-[340px] w-full p-6 flex flex-col gap-4 border border-outline/10 shadow-elevation-5 transform scale-95 transition-transform duration-200"
    >
      <div class="flex flex-col gap-1">
        <h3 class="text-base font-extrabold text-on-surface">
          Venue Logistics
        </h3>
        <p class="text-[10px] text-on-surface-variant/80 font-medium">
          Technical & wifi configurations
        </p>
      </div>
      <div
        class="flex flex-col gap-3 bg-surface-variant/40 border border-outline/5 rounded-2xl p-4 text-xs font-medium"
      >
        <div class="flex justify-between border-b border-outline/5 pb-2">
          <span class="text-on-surface-variant">Location:</span>
          <span class="text-on-surface font-bold text-right"
            >Tech Hub Orlando</span
          >
        </div>
        <div class="flex justify-between border-b border-outline/5 pb-2">
          <span class="text-on-surface-variant">Room:</span>
          <span class="text-on-surface">Main Hall (Floor 1)</span>
        </div>
        <div class="flex justify-between border-b border-outline/5 pb-2">
          <span class="text-on-surface-variant">SSID:</span>
          <span class="text-primary font-bold">TechHub_Guest</span>
        </div>
        <div class="flex justify-between border-b border-outline/5 pb-2">
          <span class="text-on-surface-variant">Wifi Pass:</span>
          <span class="text-primary font-bold">GDGOrlando2025</span>
        </div>
        <div class="flex justify-between">
          <span class="text-on-surface-variant">Technical Lead:</span>
          <span class="text-on-surface font-semibold">(407) 555-0199</span>
        </div>
      </div>
      <button
        data-modal-close
        class="btn btn-filled w-full py-2.5 text-xs font-bold cursor-pointer mt-1"
      >
        Close
      </button>
    </div>
  </div>

  <!-- 5. Notes Modal -->
  <div
    id="modal-notes"
    class="fixed inset-0 z-50 bg-black/60 backdrop-blur-sm flex items-center justify-center p-4 opacity-0 pointer-events-none transition-opacity duration-200"
    role="dialog"
    aria-modal="true"
  >
    <div
      class="bg-surface rounded-[28px] max-w-[340px] w-full p-6 flex flex-col gap-4 border border-outline/10 shadow-elevation-5 transform scale-95 transition-transform duration-200"
    >
      <div class="flex flex-col gap-1">
        <h3 class="text-base font-extrabold text-on-surface">
          Organizer Notes
        </h3>
        <p class="text-[10px] text-on-surface-variant/80 font-medium">
          Quick notes (saved locally)
        </p>
      </div>
      <textarea
        id="scratchpad-area"
        class="w-full h-36 p-3.5 border border-outline/25 rounded-2xl bg-surface-variant/20 text-xs text-on-surface font-medium focus:outline-none focus:border-primary leading-normal"
        placeholder="Type setup notes, checklist details, or reminders here..."
      ></textarea>
      <button
        data-modal-close
        class="btn btn-filled w-full py-2.5 text-xs font-bold cursor-pointer mt-1"
      >
        Save & Close
      </button>
    </div>
  </div>

  <!-- 6. Checklist Modal -->
  <div
    id="modal-checklist"
    class="fixed inset-0 z-50 bg-black/60 backdrop-blur-sm flex items-center justify-center p-4 opacity-0 pointer-events-none transition-opacity duration-200"
    role="dialog"
    aria-modal="true"
  >
    <div
      class="bg-surface rounded-[28px] max-w-[340px] w-full p-6 flex flex-col gap-4 border border-outline/10 shadow-elevation-5 transform scale-95 transition-transform duration-200"
    >
      <div class="flex flex-col gap-1">
        <h3 class="text-base font-extrabold text-on-surface">
          Event Checklist
        </h3>
        <p class="text-[10px] text-on-surface-variant/80 font-medium">
          Check off completed steps
        </p>
      </div>
      <div class="flex flex-col gap-3 max-h-[220px] overflow-y-auto pr-1">
        {
          [
            'Verify AV and HDMI feeds',
            'Test presenter lapel microphone',
            'Mount stand banners at front door',
            'Check in speaker & test slides',
            'Display check-in QR on projector',
            'Provide water for the speaker',
            'Verify catering setup is in hall',
          ].map((item, idx) => (
            <label class="flex items-start gap-3 text-xs text-on-surface font-medium cursor-pointer select-none">
              <input
                type="checkbox"
                data-checklist-idx={idx}
                class="w-4.5 h-4.5 rounded border-outline/35 text-primary focus:ring-primary/20 mt-0.5 cursor-pointer"
              />
              <span class="leading-tight mt-0.5">{item}</span>
            </label>
          ))
        }
      </div>
      <button
        data-modal-close
        class="btn btn-filled w-full py-2.5 text-xs font-bold cursor-pointer mt-1"
      >
        Done
      </button>
    </div>
  </div>
</BaseLayout>

<script>
  import { isUnlocked, lock } from '../../lib/organizer-auth';
  import {
    generateIntroScript,
    generateOutroScript,
  } from '../../lib/script-generator';

  // Client-side guard: if locked, redirect to unlock portal index
  if (!isUnlocked()) {
    window.location.replace('/organizer');
  }

  // Load events and run dynamic script generation
  const container = document.getElementById('dashboard-container');
  const currentEvent = container?.dataset.currentEvent
    ? JSON.parse(container.dataset.currentEvent)
    : null;
  const nextEvent = container?.dataset.nextEvent
    ? JSON.parse(container.dataset.nextEvent)
    : null;

  if (currentEvent) {
    const storageKey = `gdg-event-notes-${currentEvent.id}`;
    let talkingPoints = {};
    try {
      const savedData = localStorage.getItem(storageKey);
      if (savedData) {
        talkingPoints = JSON.parse(savedData);
      }
    } catch (e) {
      console.error('Failed to load event notes for scripts:', e);
    }

    const introText = generateIntroScript(currentEvent, {
      talkingPoints,
      nextEvent,
    });
    const outroText = generateOutroScript(currentEvent, {
      talkingPoints,
      nextEvent,
    });

    const introEl = document.getElementById('intro-text');
    const outroEl = document.getElementById('outro-text');
    if (introEl) introEl.textContent = introText;
    if (outroEl) outroEl.textContent = outroText;
  } else {
    // Basic fallback if no active event is returned
    const introEl = document.getElementById('intro-text');
    const outroEl = document.getElementById('outro-text');
    if (introEl) {
      introEl.textContent =
        "Welcome everyone to today's Google Developer Groups event! We are thrilled to have you here in Orlando. Remember to join our Discord community, scan the check-in QR codes, and review the Code of Conduct. Let's get started!";
    }
    if (outroEl) {
      outroEl.textContent =
        "Thank you all for joining us today! Please take a moment to join our Discord if you haven't yet, enjoy the networking session, grab some refreshments, and have a safe trip home!";
    }
  }

  // Lock action handler
  const lockBtn = document.getElementById('lock-btn');
  if (lockBtn) {
    lockBtn.addEventListener('click', () => {
      lock();
      window.location.replace('/organizer');
    });
  }

  // Generic modal open triggers
  const cards = document.querySelectorAll('[data-modal-id]');
  cards.forEach((card) => {
    card.addEventListener('click', () => {
      const modalId = card.getAttribute('data-modal-id');
      const modal = document.getElementById(`modal-${modalId}`);
      if (modal) {
        modal.classList.remove('opacity-0', 'pointer-events-none');
        modal.firstElementChild?.classList.remove('scale-95');
        modal.firstElementChild?.classList.add('scale-100');
      }
    });
  });

  // Generic modal close triggers
  const closeBtns = document.querySelectorAll('[data-modal-close]');
  closeBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const modal = btn.closest('[role="dialog"]');
      if (modal) {
        modal.classList.add('opacity-0', 'pointer-events-none');
        modal.firstElementChild?.classList.remove('scale-100');
        modal.firstElementChild?.classList.add('scale-95');
      }
    });
  });

  // Notes scratchpad synchronization
  const scratchpad = document.getElementById(
    'scratchpad-area'
  ) as HTMLTextAreaElement | null;
  if (scratchpad) {
    scratchpad.value = localStorage.getItem('gdg-organizer-notes') || '';
    scratchpad.addEventListener('input', () => {
      localStorage.setItem('gdg-organizer-notes', scratchpad.value);
    });
  }

  // Checklist items synchronization
  const checkboxes = document.querySelectorAll(
    'input[data-checklist-idx]'
  ) as NodeListOf<HTMLInputElement>;
  const loadChecklist = () => {
    try {
      const data = localStorage.getItem('gdg-organizer-checklist');
      if (data) {
        const states = JSON.parse(data);
        checkboxes.forEach((cb) => {
          const idx = cb.getAttribute('data-checklist-idx');
          if (idx !== null && states[idx] !== undefined) {
            cb.checked = states[idx];
          }
        });
      }
    } catch (e) {
      console.error(e);
    }
  };

  const saveChecklist = () => {
    const states: Record<string, boolean> = {};
    checkboxes.forEach((cb) => {
      const idx = cb.getAttribute('data-checklist-idx');
      if (idx !== null) {
        states[idx] = cb.checked;
      }
    });
    localStorage.setItem('gdg-organizer-checklist', JSON.stringify(states));
  };

  checkboxes.forEach((cb) => {
    cb.addEventListener('change', saveChecklist);
  });

  loadChecklist();

  // Clipboard copy handlers
  const copyBtns = document.querySelectorAll('[data-copy-target]');
  copyBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const targetId = btn.getAttribute('data-copy-target');
      if (targetId) {
        const textElement = document.getElementById(targetId);
        if (textElement) {
          const text = textElement.textContent?.trim() || '';
          navigator.clipboard.writeText(text).then(() => {
            const originalText = btn.textContent;
            btn.textContent = 'Copied!';
            btn.classList.add('text-success', 'border-success/30');
            setTimeout(() => {
              btn.textContent = originalText;
              btn.classList.remove('text-success', 'border-success/30');
            }, 2000);
          });
        }
      }
    });
  });
</script>
