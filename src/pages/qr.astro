---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
import { PUBLIC_LINKS } from '../config/links';

const getContainerColorClasses = (colorToken: string) => {
  switch (colorToken) {
    case 'primary':
      return 'bg-primary/10 text-primary border-primary/20';
    case 'secondary':
      return 'bg-secondary/10 text-secondary border-secondary/20';
    case 'accent':
      return 'bg-tertiary/10 text-tertiary border-tertiary/20';
    case 'error':
      return 'bg-error/10 text-error border-error/20';
    case 'success':
      return 'bg-secondary/10 text-secondary border-secondary/20';
    case 'purple':
      return 'bg-purple-500/10 text-purple-600 border-purple-500/20 dark:text-purple-400';
    default:
      return 'bg-surface-variant/10 text-on-surface-variant/80 border-outline/25';
  }
};
---

<BaseLayout
  title="QR Center | GDG Event Companion"
  description="Scan or tap to show full screen QR codes perfect for projecting"
>
  <!-- Load client-side QRCode generator library -->
  <script
    src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"
    is:inline></script>

  <div class="flex flex-col gap-5 py-2">
    <div class="flex flex-col gap-1 text-center sm:text-left">
      <h2 class="text-xl font-bold">QR Center</h2>
      <p class="text-[12px] text-on-surface-variant leading-relaxed">
        Scan or tap to show full screen QR codes perfect for projecting.
      </p>
    </div>

    <!-- QR List -->
    <div class="flex flex-col gap-3">
      {
        PUBLIC_LINKS.map((item) => (
          <div
            class="qr-trigger card card-outlined border-outline/25 p-3.5 flex justify-between items-center bg-surface/50 hover:border-primary/60 hover:bg-surface transition-all duration-200 cursor-pointer w-full text-left rounded-2xl"
            role="button"
            tabindex="0"
            data-title={item.title}
            data-url={item.url}
            data-icon={item.icon}
          >
            <div class="flex items-center gap-3">
              <div
                class={`w-12 h-12 rounded-xl flex items-center justify-center ${getContainerColorClasses(item.colorToken)}`}
              >
                <Icon name={item.icon} size={24} />
              </div>
              <div class="flex flex-col">
                <h3 class="text-sm font-bold text-on-surface">{item.title}</h3>
                <p class="text-[12px] text-on-surface-variant font-medium mt-0.5">
                  {item.description}
                </p>
                <span class="text-[11px] text-primary font-mono truncate max-w-[180px] mt-0.5">
                  {item.url.replace('https://', '')}
                </span>
              </div>
            </div>

            {/* Dynamic QR Thumbnail Container populated by client script */}
            <div
              class="qr-thumbnail w-12 h-12 bg-white p-0.5 border border-outline/20 rounded-lg flex items-center justify-center relative shrink-0 overflow-hidden"
              data-qr-url={item.url}
            />
          </div>
        ))
      }
    </div>
  </div>

  <!-- Fullscreen Modal Overlay for projecting QRs -->
  <div
    id="qr-modal"
    class="fixed inset-0 z-50 bg-black/60 backdrop-blur-sm flex items-center justify-center p-4 opacity-0 pointer-events-none transition-opacity duration-200"
    role="dialog"
    aria-modal="true"
  >
    <div
      class="bg-surface rounded-[28px] max-w-[320px] w-full p-6 flex flex-col items-center gap-5 border border-outline/10 shadow-elevation-5 transform scale-95 transition-transform duration-200"
    >
      <div class="flex flex-col items-center gap-1 text-center w-full">
        <h3 id="modal-title" class="text-lg font-bold text-on-surface">
          QR Code
        </h3>
        <a
          id="modal-url"
          href="#"
          target="_blank"
          rel="noopener noreferrer"
          class="text-[12px] text-primary hover:underline font-mono truncate w-full max-w-[240px] mt-0.5 block"
        >
          url
        </a>
      </div>

      <!-- Large QR Code Projection Container -->
      <div class="relative flex items-center justify-center shrink-0">
        <div
          id="modal-qr-code"
          class="w-64 h-64 bg-white p-2.5 rounded-[24px] flex items-center justify-center border border-outline/15 shadow-elevation-2 overflow-hidden"
        >
          <!-- Dynamic QR code generated by client script -->
        </div>

        <!-- Centered Custom Brand Logo Badge -->
        <div
          id="modal-qr-logo"
          class="absolute w-12 h-12 bg-white rounded-full border border-outline/15 shadow-elevation-2 flex items-center justify-center p-1.5 transition-all duration-200"
        >
          <!-- Loaded dynamically: an icon element matching the brand -->
        </div>
      </div>

      <button
        id="modal-close"
        class="btn btn-tonal w-full py-2.5 text-xs font-bold"
      >
        Close / Back
      </button>
    </div>
  </div>
</BaseLayout>

<script>
  const qrTriggers = document.querySelectorAll('.qr-trigger');
  const modal = document.getElementById('qr-modal');
  const modalTitle = document.getElementById('modal-title');
  const modalUrl = document.getElementById('modal-url');
  const modalQrCode = document.getElementById('modal-qr-code');
  const modalQrLogo = document.getElementById('modal-qr-logo');
  const modalClose = document.getElementById('modal-close');

  const getBrandColorClass = (iconName: string) => {
    switch (iconName) {
      case 'discord':
        return 'text-[#5865F2]';
      case 'calendar':
        return 'text-[#ea4335]';
      case 'home':
        return 'text-[#f9ab00]';
      case 'devfest':
        return 'text-[#34a853]';
      case 'codeOfConduct':
        return 'text-[#a142f4]';
      case 'community':
        return 'text-[#a142f4]';
      case 'linkedin':
        return 'text-[#0077b5]';
      default:
        return 'text-primary';
    }
  };

  interface QRCodeInstance {
    clear(): void;
    makeCode(text: string): void;
  }

  interface QRCodeConstructor {
    new (
      element: HTMLElement | string,
      options: {
        text: string;
        width?: number;
        height?: number;
        colorDark?: string;
        colorLight?: string;
        correctLevel?: number;
      }
    ): QRCodeInstance;
    CorrectLevel: {
      L: number;
      M: number;
      Q: number;
      H: number;
    };
  }

  declare const QRCode: QRCodeConstructor;

  const initQRCodes = () => {
    if (typeof QRCode === 'undefined') {
      // Retry loading if CDN is slightly delayed
      setTimeout(initQRCodes, 50);
      return;
    }

    const qrThumbnails =
      document.querySelectorAll<HTMLElement>('.qr-thumbnail');
    qrThumbnails.forEach((thumbnail) => {
      thumbnail.innerHTML = '';
      const url = thumbnail.getAttribute('data-qr-url') || '';
      if (url) {
        new QRCode(thumbnail, {
          text: url,
          width: 40,
          height: 40,
          colorDark: '#000000',
          colorLight: '#ffffff',
          correctLevel: QRCode.CorrectLevel.M,
        });
      }
    });
  };

  if (
    modal &&
    modalTitle &&
    modalUrl &&
    modalQrCode &&
    modalQrLogo &&
    modalClose
  ) {
    qrTriggers.forEach((trigger) => {
      trigger.addEventListener('click', () => {
        const title = trigger.getAttribute('data-title') || '';
        const url = trigger.getAttribute('data-url') || '';
        const icon = trigger.getAttribute('data-icon') || 'qr';

        modalTitle.textContent = title;
        modalUrl.textContent = url.replace('https://', '');
        modalUrl.setAttribute('href', url);

        // Clear previous QR code
        modalQrCode.innerHTML = '';

        // Generate large QR code
        if (typeof QRCode !== 'undefined') {
          new QRCode(modalQrCode, {
            text: url,
            width: 236,
            height: 236,
            colorDark: '#000000',
            colorLight: '#ffffff',
            correctLevel: QRCode.CorrectLevel.H, // High error correction to support centered logo overlay
          });
        }

        // Set centered brand logo badge inside projection QR code
        const colorClass = getBrandColorClass(icon);
        modalQrLogo.innerHTML = `<span class="icon-base icon-${icon} w-7 h-7 ${colorClass}" role="img" aria-label="${icon} icon"></span>`;

        // Open modal
        modal.classList.remove('opacity-0', 'pointer-events-none');
        modal.firstElementChild?.classList.remove('scale-95');
        modal.firstElementChild?.classList.add('scale-100');
      });

      // Keyboard accessibility
      trigger.addEventListener('keydown', (e) => {
        const keyEvent = e as KeyboardEvent;
        if (keyEvent.key === 'Enter' || keyEvent.key === ' ') {
          keyEvent.preventDefault();
          (trigger as HTMLElement).click();
        }
      });
    });

    const closeModal = () => {
      modal.classList.add('opacity-0', 'pointer-events-none');
      modal.firstElementChild?.classList.remove('scale-100');
      modal.firstElementChild?.classList.add('scale-95');
    };

    modalClose.addEventListener('click', closeModal);
    modal.addEventListener('click', (e) => {
      if (e.target === modal) closeModal();
    });
  }

  // Initialize page list thumbnails
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initQRCodes);
  } else {
    initQRCodes();
  }
</script>
