---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
---

<BaseLayout
  title="QR Center | GDG Event Companion"
  description="Scan ticket or check in to event locations"
>
  <div class="flex flex-col items-center gap-6 py-6 text-center">
    <div class="flex flex-col items-center gap-2">
      <h2 class="text-xl font-bold">QR Center</h2>
      <p class="text-xs text-on-surface-variant max-w-xs">
        Use your personalized ticket QR code for quick check-ins at session
        rooms and registration desks.
      </p>
    </div>

    <!-- Mock QR Code Container -->
    <div
      class="card card-elevated p-6 flex flex-col items-center justify-center gap-4 bg-surface max-w-[280px] w-full border border-outline/10 shadow-elevation-2"
    >
      <div
        class="w-48 h-48 bg-on-surface/5 rounded-2xl flex items-center justify-center border-2 border-dashed border-outline/35 relative overflow-hidden group"
      >
        <!-- Interactive target lines -->
        <div class="absolute inset-4 border-2 border-primary/45 rounded-lg">
        </div>
        <div class="absolute inset-0 bg-primary/5 animate-pulse"></div>
        <!-- Mock QR Scanner Graphic -->
        <Icon name="qr" size={72} class="text-primary/70 animate-bounce" />
      </div>
      <div class="flex flex-col gap-0.5">
        <span
          class="text-[10px] text-on-surface-variant font-bold uppercase tracking-wider"
          >Ticket Code</span
        >
        <code
          class="text-xs font-mono bg-surface-variant/40 px-2 py-0.5 rounded text-on-surface"
          >GDG-2026-COMPANION</code
        >
      </div>
    </div>

    <!-- Instruction Info -->
    <div class="card card-filled p-4 text-left w-full max-w-xs flex gap-3">
      <div class="text-secondary text-lg shrink-0">🛡️</div>
      <div class="flex flex-col gap-0.5">
        <h3 class="text-xs font-bold">Offline Available</h3>
        <p class="text-[10px] text-on-surface-variant leading-relaxed">
          Your check-in token is cached on device. You can check in even when
          the venue Wi-Fi is offline!
        </p>
      </div>
    </div>
  </div>
</BaseLayout>
